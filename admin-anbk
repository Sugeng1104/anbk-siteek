<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Admin ANBK | Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:"Segoe UI", Arial, sans-serif;
      background:#eef1f5;
      color:#333;
    }

    header{
      background:#1e3a8a;
      color:white;
      padding:18px 28px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }
    header h1{
      margin:0;
      font-size:20px;
      font-weight:600;
      letter-spacing:.3px;
    }
    header .user{
      font-size:13px;
      opacity:.9;
    }

    .layout{
      display:flex;
      min-height:calc(100vh - 64px);
    }

    aside{
      width:260px;
      background:#ffffff;
      border-right:1px solid #dcdcdc;
      padding:22px 0;
    }
    aside h3{
      margin:0 24px 12px;
      font-size:12px;
      color:#666;
      text-transform:uppercase;
    }
    aside a{
      display:block;
      padding:12px 24px;
      font-size:14px;
      color:#333;
      text-decoration:none;
    }
    aside a:hover,
    aside a.active{
      background:#eef5ff;
      color:#1e3a8a;
      font-weight:600;
    }

    main{
      flex:1;
      padding:28px;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:20px;
      margin-bottom:28px;
    }

    .card{
      background:white;
      border-radius:10px;
      padding:20px;
      box-shadow:0 2px 6px rgba(0,0,0,.08);
    }
    .card h4{
      margin:0 0 6px;
      font-size:14px;
      color:#666;
    }
    .card .value{
      font-size:26px;
      font-weight:600;
      color:#1e3a8a;
    }

    .section{
      background:white;
      border-radius:10px;
      padding:20px;
      box-shadow:0 2px 6px rgba(0,0,0,.08);
      margin-bottom:24px;
    }

    .section h2{
      margin-top:0;
      font-size:16px;
      color:#1e3a8a;
    }

    table{
      width:100%;
      border-collapse:collapse;
      font-size:14px;
    }
    th,td{
      border:1px solid #ddd;
      padding:10px;
      text-align:center;
    }
    th{
      background:#f4f6fa;
      font-weight:600;
    }

    footer{
      text-align:center;
      font-size:12px;
      color:#777;
      margin-top:30px;
    }
  </style>
</head>

<body>

<header>
  <h1>ADMIN ANBK – DASHBOARD UTAMA</h1>
  <div class="user">
    Admin ANBK | <span id="adminEmail"></span>
  </div>
</header>

<div class="layout">

  <aside>
    <h3>Menu Admin</h3>
    <a href="#" class="active">Dashboard</a>
    <a href="#">Manajemen Proktor</a>
    <a href="#">Sesi & Jadwal ANBK</a>
    <a href="#">Monitoring Nasional</a>
    <a href="#">Rekap & Laporan</a>
    <a href="#" onclick="logout()">Logout</a>
  </aside>

  <main>

    <!-- STATISTIK -->
    <div class="cards">
      <div class="card">
        <h4>Total Proktor</h4>
        <div class="value" id="totalProktor">–</div>
      </div>
      <div class="card">
        <h4>Total Peserta</h4>
        <div class="value" id="totalPeserta">–</div>
      </div>
      <div class="card">
        <h4>Sesi Aktif</h4>
        <div class="value" id="sesiAktif">–</div>
      </div>
      <div class="card">
        <h4>Status Server</h4>
        <div class="value" style="color:#059669">NORMAL</div>
      </div>
    </div>

    <!-- RINGKASAN -->
    <div class="section">
      <h2>Ringkasan Pelaksanaan ANBK</h2>
      <table>
        <thead>
          <tr>
            <th>Ruang</th>
            <th>Proktor</th>
            <th>Peserta Aktif</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="ringkasan">
          <tr>
            <td colspan="4">Memuat data...</td>
          </tr>
        </tbody>
      </table>
    </div>

    <footer>
      © 2026 Sistem ANBK Sekolah • Admin Nasional
    </footer>

  </main>
</div>

<script>
/* ===== SESSION ===== */
const email = localStorage.getItem("email");
const role  = localStorage.getItem("role");

if (!email || role !== "admin-anbk") {
  alert("Akses hanya untuk Admin ANBK");
  location.href = "login.html";
}

document.getElementById("adminEmail").innerText = email;

/* ===== DATA CONTOH (DUMMY, BACKEND NANTI) ===== */
document.getElementById("totalProktor").innerText = "3";
document.getElementById("totalPeserta").innerText = "120";
document.getElementById("sesiAktif").innerText = "2";

document.getElementById("ringkasan").innerHTML = `
  <tr>
    <td>Ruang 1</td>
    <td>proktor1@sekolah.id</td>
    <td>38</td>
    <td>Berjalan</td>
  </tr>
  <tr>
    <td>Ruang 2</td>
    <td>proktor2@sekolah.id</td>
    <td>40</td>
    <td>Berjalan</td>
  </tr>
`;

/* ===== LOGOUT ===== */
function logout(){
  localStorage.clear();
  location.href = "login.html";
}
</script>

</body>
</html>
